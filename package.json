{
    "name": "graphql-api-testing",
    "version": "0.0.1",
    "description": "API testing template with Playwright, TypeScript, GraphQL and OAuth 2.0",
    "scripts": {
        "test": "playwright test",
        "test:debug": "DEBUG=pw:api playwright test --debug",
        "test:report": "playwright show-report",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "playwright",
        "api-testing",
        "graphql",
        "oauth2",
        "typescript",
        "integration-tests"
    ],
    "author": "Sonje",
    "license": "ISC",
    "dependencies": {
        "@playwright/test": "^1.58.2",
        "cockatiel": "3.2.1",
        "dotenv": "^17.3.1",
        "graphql": "^16.13.1",
        "graphql-request": "^7.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=25.0.0"
    }
}
