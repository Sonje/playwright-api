GRAPHQL_ENDPOINT=https://someapp.com/graphql

# OAuth 2.0 Configuration (Azure B2C)
AUTH_URL=https://someapp.b2clogin.com/someapp.onmicrosoft.com/b2c_1_signin/oauth2/v2.0/authorize

# Token URL - used to exchange authorization code for access token
TOKEN_URL=https://someapp.b2clogin.com/someapp.onmicrosoft.com/b2c_1_signin/oauth2/v2.0/token

CLIENT_ID=b660c144-2ae0-4a97-8ea5-f504acc62c81

REDIRECT_URI=com.someapp://auth/

# OAuth Scope
SCOPE=https://someapp.onmicrosoft.com/someapp-api/someapp.Api

# Optional: Pre-configured Access Token
# If provided, tests will skip OAuth flow and use this token directly
# ACCESS_TOKEN=your_access_token_here

# Optional: Test Configuration
# Timeout for each test in milliseconds (default: 30000)
TEST_TIMEOUT=30000

# Number of retries for failed tests (default: 2)
TEST_RETRIES=2
